rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // Collection: posts
    //   - id, title, excerpt, content, author, date, category,
    //     imageUrl, readTime, status ('published'|'draft')
    //
    // Collection: comments
    //   - id, postId, authorName, authorEmail, content, date, isApproved
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // isAdmin: checks email only (email/password accounts are not auto-verified)
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "netbiz0925@gmail.com";
    }

    function isValidPost(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'author', 'date', 'category', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 &&
             data.status in ['published', 'draft'];
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'postId', 'authorName', 'content', 'date', 'isApproved']) &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             data.isApproved is bool;
    }

    // Posts Rules
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if isAdmin() && isValidPost(request.resource.data);
      allow delete: if isAdmin();
    }

    // Comments Rules
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isValidComment(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
